:"RotorsLowRate", "Description":"", "Extras":[]},{"Name":"RotorsHighRate", "Description":"", "Extras":[]}], "Extras":[]}], "Strings":{}},{"Locale":"en", "Name":"SprinklerZone", "DisplayName":"SprinklerZone", "Description":"", "List":[{"Type":0, "Name":"SprinklerZone", "Description":"", "Extras":[]},{"Type":1, "Name":"Sprinkler zone", "Description":"In an irrigation system, a sprinkler zone is a specific group of sprinklers that are controlled by a single dedicated valve and operate simultaneously to water an area of plants.", "Extras":[]},{"Type":2, "Name":"field_capacity", "Description":"", "Extras":[]},{"Type":3, "Name":"soil_type", "Description":"", "Enum":[], "Extras":[]},{"Type":4, "Name":"plant_type", "Description":"", "Enum":[], "Extras":[]},{"Type":5, "Name":"head", "Description":"", "Enum":[], "Extras":[]},{"Type":6, "Name":"zone_info", "Description":"", "Extras":[]}], "Strings":{}},{"Locale":"en", "Name":"SprinklerZoneInfo", "DisplayName":"SprinklerZoneInfo", "Description":"", "List":[{"Type":0, "Name":"SprinklerZoneInfo", "Description":"The sprinkler zone's schedule information.", "Extras":[]},{"Type":1, "Name":"Next watering schedule", "Description":"The next scheduled watering time and duration. This schedule is dynamically calculated and may change later. The calculation must avoid the hold-off periods.", "Extras":[]},{"Type":2, "Name":"Hold off periods", "Description":"The list of sprinkler's hold-off period that the dynamic calculation of watering schedule must avoid. A hold-off ensures a sprinkler zone (area) won't be watered during the period.", "Extras":[]},{"Type":3, "Name":"Hold off period", "Description":"A start time and duration of a hold-off period.", "Extras":[]}], "Strings":{}},{"Locale":"en", "Name":"TimeSlot", "DisplayName":"TimeSlot", "Description":"", "List":[{"Type":0, "Name":"A time period", "Description":"Including a start time and a duration.", "Extras":[]},{"Type":1, "Name":"Start time", "Description":"The start time.", "Extras":[]},{"Type":2, "Name":"Duration", "Description":"The duration.", "Extras":[]}], "Strings":{}},{"Locale":"en", "Name":"UpdateHoldOffRequest", "DisplayName":"UpdateHoldOffRequest", "Description":"", "List":[{"Type":0, "Name":"UpdateHoldOffRequest", "Description":"Request to update the list of a sprinkler zone’s hold-off period. A hold-off ensures a zone (area) won't be watered during the period. The dynamic calculation of the watering schedule must avoid the hold-off periods! A user hold-off must be honored even if it does not overlap with the watering schedule!", "Extras":[]},{"Type":1, "Name":"Hold off period list", "Description":"A list of hold off periods.", "Extras":[]},{"Type":2, "Name":"Hold off period", "Description":"A hold off period with start time and duration.", "Extras":[]}], "Strings":{}},{"Locale":"en", "Name":"ZoneDataProtocol", "DisplayName":"ZoneDataProtocol", "Description":"", "List":[{"Type":0, "Name":"ZoneDataProtocol", "Description":"", "Extras":[]},{"Type":1, "Name":"Get zone information", "Description":"Get the sprinkler runtime information for the zone.", "Extras":[]},{"Type":2, "Name":"Zone information", "Description":"Information about the sprinkler zone's next watering schedule and hold-off period list. A hold-off ensures the zone won't be watered during the period.", "Extras":[]},{"Type":3, "Name":"Update hold off periods", "Description":"A request to update the entire list of \"hold off\" periods of the sprinkler zone. The system ensures the zone won't be watered during each hold off period.", "Extras":[]}], "Strings":{}}]}
col", "Description":"", "List":[{"Type":0, "Name":"灌溉区域数据协议", "Description":"", "Extras":[]},{"Type":1, "Name":"获取灌溉区域信息", "Description":"得到本灌溉区域的运行信息。", "Extras":[]},{"Type":2, "Name":"灌溉区域信息", "Description":"包括本区域下次灌溉计划时间和时长，以及暂停期列表。", "Extras":[]},{"Type":3, "Name":"更新暂停期列表请求", "Description":"请求更新暂停期列表。暂停期确保灌溉程序不会浇水，而且动态浇水计划的计算也会避开暂停期。因此用户的暂停期请求具有更高优先级。", "Extras":[]}], "Strings":{}}]}